{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with roles and basic info",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "driver", "admin"] },
        "status": { "type": "string", "enum": ["online", "offline", "busy"] },
        "currentLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "email", "role"]
    },
    "Delivery": {
      "title": "Delivery",
      "description": "Delivery request and its status",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "driverId": { "type": "string" },
        "from": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "to": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "cost": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "picked_up", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "from", "to", "cost", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile storage"
    },
    "/deliveries/{deliveryId}": {
      "schema": "Delivery",
      "description": "Delivery requests storage"
    },
    "/deliveries/{deliveryId}/tracking/{trackId}": {
      "schema": {
        "type": "object",
        "properties": {
          "lat": { "type": "number" },
          "lng": { "type": "number" },
          "timestamp": { "type": "string", "format": "date-time" }
        }
      },
      "description": "Real-time tracking for a specific delivery"
    }
  }
}
